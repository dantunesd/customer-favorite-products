{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Customer schema",
  "description": "PUT /customer body schema",
  "type": "object",
  "examples": [
      {
          "email": "email@email.com",
          "name": "A green door"
      }
  ],
  "required": [
      "email",
      "name"
  ],
  "properties": {
      "email": {
          "type": "string",
          "description": "the customer email",
          "examples": [
            "email@email.com"
          ]
        },
        "name": {
          "type": "string",
          "description": "The customer name",
            "examples": [
              "Name Lastname"
          ]
      }
  },
  "additionalProperties": false
}